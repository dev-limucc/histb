  "contact": {
    "sources": "https://github.com/dev-limucc/histb"
  },
  "license": "MIT",
  "icon": "assets/histb/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": ["dev.limucc.histb.client.HistbClient"],
    "modmenu": ["dev.limucc.histb.client.gui.ModMenuIntegration"]
  },
  "depends": {
    "fabricloader": ">=0.19.2",
    "minecraft": "~26.1",
    "java": ">=25",
    "fabric-api": "*",
    "malilib": "*"
  }
}
